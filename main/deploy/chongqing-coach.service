[Unit]
Description=Chongqing Coach MVP FastAPI service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/KeepTouch/chongqing-coach-mvp
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/KeepTouch/chongqing-coach-mvp/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
