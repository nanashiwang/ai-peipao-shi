# ── 企业微信「会话内容存档」配置模板 ───────────────────────────────
# 复制为 main/.env（已在 .gitignore，不会入库），按注释填写后重建容器生效。
# 未开通/未配置时保持 WECOM_ARCHIVE_ENABLED=false，不影响系统其它功能。

# 总开关：开通并配置完成后设为 true
WECOM_ARCHIVE_ENABLED=false

# 后台自动增量同步：设为 true 后按 seq 游标定时拉取新消息
WECOM_ARCHIVE_POLL_ENABLED=false
WECOM_ARCHIVE_POLL_INTERVAL_SECONDS=60

# 企业微信后台「会话内容存档」页获取
WECOM_ARCHIVE_CORP_ID=
WECOM_ARCHIVE_SECRET=

# 官方 Finance SDK 的 Linux .so，放到 main/config/ 下，容器内路径如下
WECOM_ARCHIVE_SDK_PATH=/app/config/libWeWorkFinanceSdk_C.so

# RSA 私钥（与后台填写的公钥配对，用于解密 random_key）二选一：
#  A) 直接贴 PEM 或其 base64（单行）
WECOM_ARCHIVE_PRIVATE_KEY=
#  B) 或把 .pem 放 main/config/ 下，用路径指向（推荐）
WECOM_ARCHIVE_PRIVATE_KEY_PATH=/app/config/wecom_archive_private_key.pem

# 可选：企业出口代理（SDK 拉取需固定可信 IP 时）
WECOM_ARCHIVE_PROXY=
WECOM_ARCHIVE_PROXY_PASSWD=

# 单批拉取条数与超时
WECOM_ARCHIVE_LIMIT=100
WECOM_ARCHIVE_TIMEOUT_SECONDS=30

# 自己方（陪跑师）的 userid，逗号分隔——用于把发言人标成「我」
WECOM_ARCHIVE_SELF_USERIDS=

# 可选映射（JSON 字符串）：
#  会话→家庭/目标名，把存档的 roomid/userid 对到系统里的 family
WECOM_ARCHIVE_CONVERSATION_MAP={}
#  userid→显示名
WECOM_ARCHIVE_USER_MAP={}

# 拉到新消息时是否自动生成 AI 回复草稿 / 自动建发送任务
WECOM_ARCHIVE_AUTO_REPLY=false
WECOM_ARCHIVE_AUTO_CREATE_TASK=false

# ── 微信客服 API：家长在个人微信咨询，系统通过微信客服账号回复 ──
WECOM_KF_ENABLED=false
WECOM_KF_CORP_ID=
WECOM_KF_SECRET=
# 微信客服管理后台「开发配置」中自定义，Token 不超过32位，EncodingAESKey 固定43位
WECOM_KF_TOKEN=
WECOM_KF_ENCODING_AES_KEY=
# 可选；收到回调后会自动发现 open_kfid，首次主动轮询时建议填写
WECOM_KF_DEFAULT_OPEN_KFID=
WECOM_KF_POLL_ENABLED=true
WECOM_KF_POLL_INTERVAL_SECONDS=5
WECOM_KF_DISPATCH_ENABLED=true
