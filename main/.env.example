# local/development/dev/test/pilot/staging/production
APP_ENV=local

# 本地开发默认 SQLite；试点/正式 Docker 建议使用下面的 PostgreSQL 组合。
DATABASE_URL=sqlite:///./coach_mvp.db
POSTGRES_DB=coach_mvp
POSTGRES_USER=coach
POSTGRES_PASSWORD=change-me-before-production

SEND_LOG_RETENTION_DAYS=365
SEND_SCREENSHOT_RETENTION_DAYS=90
RUNTIME_LOG_RETENTION_DAYS=30

ADMIN_AUTH_REQUIRED=true
ADMIN_AUTH_SECRET=change-me-before-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
ADMIN_DISPLAY_NAME=系统管理员
ADMIN_RATE_LIMIT_ENABLED=true
ADMIN_API_RATE_LIMIT=240
ADMIN_API_RATE_WINDOW_SECONDS=60
ADMIN_LOGIN_RATE_LIMIT=10
ADMIN_LOGIN_RATE_WINDOW_SECONDS=60

MOCK_AI=true
MOCK_RPA=true
