# local/development/dev/test/pilot/staging/production
APP_ENV=local

# 本地开发默认 SQLite；试点/正式 Docker 建议使用下面的 PostgreSQL 组合。
DATABASE_URL=sqlite:///./coach_mvp.db
POSTGRES_DB=coach_mvp
POSTGRES_USER=coach
POSTGRES_PASSWORD=change-me-before-production

SEND_LOG_RETENTION_DAYS=365
SEND_SCREENSHOT_RETENTION_DAYS=90
RUNTIME_LOG_RETENTION_DAYS=30

ADMIN_AUTH_REQUIRED=true
ADMIN_AUTH_SECRET=change-me-before-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
ADMIN_DISPLAY_NAME=系统管理员
ADMIN_RATE_LIMIT_ENABLED=true
ADMIN_API_RATE_LIMIT=240
ADMIN_API_RATE_WINDOW_SECONDS=60
ADMIN_LOGIN_RATE_LIMIT=10
ADMIN_LOGIN_RATE_WINDOW_SECONDS=60

MOCK_AI=true
MOCK_RPA=true

# 微信客服 API（完整说明见 .env.wecom.example）
WECOM_KF_ENABLED=false
WECOM_KF_CORP_ID=
WECOM_KF_SECRET=
WECOM_KF_TOKEN=
WECOM_KF_ENCODING_AES_KEY=
WECOM_KF_DEFAULT_OPEN_KFID=

# 企业微信客户联系（完整说明见 docs/客户联系接入.md）
WECOM_CUSTOMER_ENABLED=false
WECOM_CUSTOMER_CORP_ID=
WECOM_CUSTOMER_SECRET=
WECOM_CUSTOMER_TOKEN=
WECOM_CUSTOMER_ENCODING_AES_KEY=
WECOM_CUSTOMER_SYNC_ENABLED=true
WECOM_CUSTOMER_SYNC_INTERVAL_SECONDS=300
WECOM_CUSTOMER_DISPATCH_ENABLED=true
WECOM_CUSTOMER_WORKER_INTERVAL_SECONDS=30
WECOM_CUSTOMER_WELCOME_ENABLED=false
WECOM_CUSTOMER_WELCOME_TEXT=您好，已经收到您的添加。后续课程安排、任务提醒和学习反馈会通过这里与您同步。
