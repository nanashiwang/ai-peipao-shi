# local/development/dev/test/pilot/staging/production
APP_ENV=local

# 本地开发默认 SQLite；试点/正式 Docker 建议使用下面的 PostgreSQL 组合。
DATABASE_URL=sqlite:///./coach_mvp.db
POSTGRES_DB=coach_mvp
POSTGRES_USER=coach
POSTGRES_PASSWORD=change-me-before-production

SEND_LOG_RETENTION_DAYS=365
SEND_SCREENSHOT_RETENTION_DAYS=90
RUNTIME_LOG_RETENTION_DAYS=30

MOCK_AI=true
MOCK_RPA=true
